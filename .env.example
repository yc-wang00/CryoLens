# CryoLens Environment Variables
# Copy to .env and fill in real values

# Backend (FastAPI)
APP_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/cryosight
SQL_ECHO=false

# Anthropic API key (required for AI research agent)
ANTHROPIC_API_KEY=your-anthropic-api-key

# MCP server (engine/) — set for local dev; Railway uses internal URL automatically
CRYOLENS_DB_URL=postgresql://postgres:postgres@localhost:5433/cryosight
